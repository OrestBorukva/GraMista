# Публічна адреса застосунку — потрібна, щоб зареєструвати вебхук monobank.
# Локально — http://localhost:3000; у проді — повний https-домен.
APP_BASE_URL=http://localhost:3000

# База даних (локально — Postgres у Docker через docker-compose.yml)
DATABASE_URL="postgresql://gramista:gramista@localhost:5435/gramista?schema=public"

# Тестова БД для юніт-тестів сервісів (опційно; за замовчуванням gramista_test на тому ж Postgres).
# Одноразово: createdb gramista_test → npm run db:test:setup
# TEST_DATABASE_URL="postgresql://gramista:gramista@localhost:5435/gramista_test?schema=public"

# Better Auth — секрет підпису сесій (32 байти hex). СЕКРЕТ.
# Згенерувати: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Закрита програма: 1 — реєстрація вимкнена (ендпойнт + UI), приєднання за запрошенням.
# На проді УВІМКНЕНО (див. docker-compose.prod.yml і lib/signups.ts); локально не задавати.
# SIGNUPS_CLOSED=1

# Пошта (Resend) — підтвердження email і скидання пароля. СЕКРЕТ.
# Без ключа (локально) листи не шлються — посилання друкуються в консоль dev-сервера.
RESEND_API_KEY=
# Відправник листів (у проді — обов'язково, див. .env.prod.example; локально необов'язково)
# EMAIL_FROM="GraMista <noreply@example.com>"
