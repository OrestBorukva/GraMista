# Серверний /opt/gramista/.env (поруч із docker-compose.prod.yml).
# Згенерувати секрети: openssl rand -hex 32
POSTGRES_PASSWORD=
BETTER_AUTH_SECRET=
# Ключ Resend (resend.com) — листи підтвердження пошти і скидання пароля. СЕКРЕТ.
RESEND_API_KEY=
# Публічна адреса застосунку — повний https-домен, напр. https://gramista.example.com
APP_BASE_URL=
# Домен для Caddy (без https://) і пошта адміна для Let's Encrypt
CADDY_DOMAIN=
CADDY_EMAIL=
# Відправник листів, напр. "GraMista <noreply@gramista.example.com>"
EMAIL_FROM=
